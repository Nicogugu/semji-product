{
  "mcpServers": {
    "harvestr": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        ".harvestr-mcp",
        "fastmcp",
        "run",
        "src/harvestr_mcp/server.py:mcp"
      ],
      "env": {
        "HARVESTR_API_TOKEN": "<your-harvestr-token>"
      }
    },
    "n8n-feedbacks": {
      "_comment": "MCP server n8n pour RAG/SQL feedbacks calls — configurer separement via n8n-mcp CLI",
      "command": "n8n-mcp",
      "args": [],
      "env": {
        "MCP_MODE": "stdio",
        "N8N_API_URL": "<your-n8n-instance-url>",
        "N8N_API_KEY": "<your-n8n-api-key>"
      }
    },
    "slack": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/slack-mcp@latest"
      ],
      "env": {}
    },
    "nanobanana": {
      "command": "uvx",
      "args": [
        "nanobanana-mcp-server@latest"
      ],
      "env": {
        "GEMINI_API_KEY": "<your-gemini-api-key>"
      }
    }
  },
  "gitlab": {
    "_comment": "Token GitLab pour p.gitlab — variable d'env GITLAB_TOKEN",
    "env": {
      "GITLAB_TOKEN": "<your-gitlab-personal-access-token>"
    }
  }
}
