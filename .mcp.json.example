{
  "mcpServers": {
    "harvestr": {
      "_comment": "MCP Streamable HTTP — l'URL contient le token d'acces, ne pas committer",
      "url": "<your-harvestr-n8n-mcp-url>"
    },
    "n8n-feedbacks": {
      "_comment": "MCP Streamable HTTP — l'URL contient le token d'accès, ne pas committer",
      "url": "<your-n8n-mcp-endpoint-url>"
    },
    "slack": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/slack-mcp@latest"
      ],
      "env": {}
    },
    "nanobanana": {
      "command": "uvx",
      "args": [
        "nanobanana-mcp-server@latest"
      ],
      "env": {
        "GEMINI_API_KEY": "<your-gemini-api-key>"
      }
    }
  },
  "gitlab": {
    "_comment": "Token GitLab pour p.gitlab — variable d'env GITLAB_TOKEN",
    "env": {
      "GITLAB_TOKEN": "<your-gitlab-personal-access-token>"
    }
  }
}
